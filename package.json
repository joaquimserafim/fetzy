{
	"name": "netzap",
	"version": "1.0.0",
	"description": "Tiny, dependency-free fetch wrapper for Node and browsers: timeouts, signal merging, typed JSON helper, and a client factory.",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm run build",
		"lint": "biome check .",
		"format": "biome check --write ."
	},
	"keywords": [
		"fetch",
		"http",
		"client",
		"timeout",
		"abort",
		"abortcontroller",
		"signal",
		"json",
		"browser",
		"node",
		"typescript",
		"isomorphic"
	],
	"author": "@joaquimserafim",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/joaquimserafim/netzap.git"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "4.1.9",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
